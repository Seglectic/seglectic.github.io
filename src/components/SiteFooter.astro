---
import IconGithub from '~icons/simple-icons/github';
---

<footer>
  <div class="footer-inner">
    <a
      href="https://github.com/Seglectic"
      target="_blank"
      rel="noopener noreferrer"
      class="gh-link"
      aria-label="Seglectic on GitHub"
    >
      <IconGithub class="gh-icon" aria-hidden="true" />
    </a>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: var(--space-xl);
  }

  .footer-inner {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0.7rem 1.1rem 0.8rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    line-height: 1.2;
    color: var(--text-muted);
  }

  .gh-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
  }

  .gh-icon {
    width: 1.05rem;
    height: 1.05rem;
  }

  .gh-link:hover {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .footer-inner {
      padding: 0.7rem 0.9rem 0.8rem;
      font-size: 0.76rem;
    }
  }
</style>
