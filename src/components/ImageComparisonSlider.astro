---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt?: string;
  afterAlt?: string;
  aspectRatio?: string;
}

const { before, after, beforeAlt = 'Before', afterAlt = 'After', aspectRatio = '3 / 4' } = Astro.props;
const id = `ics-${Math.random().toString(36).slice(2, 7)}`;

const [beforeOpt, afterOpt] = await Promise.all([
  getImage({ src: before, format: 'webp', quality: 85, width: 1200 }),
  getImage({ src: after,  format: 'webp', quality: 85, width: 1200 }),
]);
---

<div class="ics" id={id} aria-label="Image comparison slider" style={`aspect-ratio: ${aspectRatio}`}>
  <img class="ics-img ics-after"  src={afterOpt.src}  alt={afterAlt}  draggable="false" />
  <img class="ics-img ics-before" src={beforeOpt.src} alt={beforeAlt} draggable="false" />
  <div
    class="ics-divider"
    role="slider"
    aria-label="Comparison divider"
    aria-valuemin={0}
    aria-valuemax={100}
    aria-valuenow={50}
    tabindex={0}
  >
    <div class="ics-handle" aria-hidden="true">
      <span class="ics-arrow ics-arrow-l">◂</span>
      <span class="ics-arrow ics-arrow-r">▸</span>
    </div>
  </div>
  <div class="ics-header">
    <span class="ics-label-before">{beforeAlt}</span>
    <span class="ics-label-after">{afterAlt}</span>
  </div>
</div>

<style>
  .ics {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border: 1px solid var(--border-subtle);
    cursor: col-resize;
    user-select: none;
    --split: 50%;
    margin: 0 0 var(--space-lg) 0;
  }

  .ics-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .ics-before {
    clip-path: inset(0 calc(100% - var(--split)) 0 0);
    z-index: 1;
  }

  .ics-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--split);
    transform: translateX(-50%);
    width: 3px;
    background: var(--accent);
    z-index: 2;
    cursor: col-resize;
    outline: none;
    touch-action: none;
  }

  .ics-divider::before {
    content: '';
    position: absolute;
    inset: 0 -10px;
  }

  .ics-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--bg);
    border: 2px solid var(--accent);
    color: var(--accent);
    pointer-events: none;
  }

  .ics-divider:focus-visible .ics-handle {
    background: var(--accent);
    color: var(--bg);
  }

  .ics-arrow {
    font-size: 0.8rem;
    line-height: 1;
  }

  .ics-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-sm);
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, transparent 100%);
    z-index: 3;
    pointer-events: none;
  }

  .ics-label-before,
  .ics-label-after {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
</style>

<script define:vars={{ id }}>
  function initSlider(root) {
    const divider = root.querySelector('.ics-divider');
    let dragging = false;

    function setSplit(pct) {
      const clamped = Math.min(100, Math.max(0, pct));
      root.style.setProperty('--split', clamped + '%');
      divider.setAttribute('aria-valuenow', Math.round(clamped));
    }

    function getPct(clientX) {
      const rect = root.getBoundingClientRect();
      return ((clientX - rect.left) / rect.width) * 100;
    }

    root.addEventListener('pointerdown', (e) => {
      dragging = true;
      root.setPointerCapture(e.pointerId);
      setSplit(getPct(e.clientX));
      e.preventDefault();
    });

    root.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      setSplit(getPct(e.clientX));
    });

    root.addEventListener('pointerup',     () => { dragging = false; });
    root.addEventListener('pointercancel', () => { dragging = false; });

    divider.addEventListener('keydown', (e) => {
      const current = parseFloat(root.style.getPropertyValue('--split') || '50');
      if (e.key === 'ArrowLeft')  { setSplit(current - 2); e.preventDefault(); }
      if (e.key === 'ArrowRight') { setSplit(current + 2); e.preventDefault(); }
    });

    setSplit(50);
  }

  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById(id);
    if (el) initSlider(el);
  });
</script>
