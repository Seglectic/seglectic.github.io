---
interface Props {
  src: string;
  alt?: string;
  poster?: string;
  materialProfile?: string;
}

const { src, alt = '3D model', poster, materialProfile } = Astro.props;
---

<div class="mv-wrap">
  <model-viewer
    src={src}
    alt={alt}
    camera-controls
    auto-rotate
    auto-rotate-delay={500}
    rotation-per-second="20deg"
    shadow-intensity="1.5"
    shadow-softness="0.4"
    exposure="1.4"
    tone-mapping="commerce"
    environment-image="neutral"
    data-material-profile={materialProfile}
    {...poster ? { poster } : {}}
  ></model-viewer>
</div>

<script>
  import '@google/model-viewer';

  const CANOPTICON_MATERIALS = {
    'Aluminum_-_Satin': {
      metallic: 0.95,
      roughness: 0.34,
      specular: 1,
      doubleSided: false,
    },
    'Aluminum_-_Bead_Blasted': {
      metallic: 0.82,
      roughness: 0.74,
      specular: 0.92,
      doubleSided: false,
    },
    'Opaque(34,88,170)': {
      metallic: 0.02,
      roughness: 0.26,
      specular: 0.62,
      doubleSided: false,
    },
    'Opaque(202,209,238)': {
      metallic: 0,
      roughness: 0.42,
      specular: 0.55,
      doubleSided: false,
    },
    'Opaque(200,142,7)': {
      metallic: 0,
      roughness: 0.5,
      specular: 0.42,
      doubleSided: false,
    },
  };

  const DEFAULT_CANOPTICON_MATERIAL = {
    metallic: 0,
    roughness: 0.88,
    specular: 0.3,
    doubleSided: false,
  };

  const applyCanopticonMaterials = (viewer) => {
    const materials = viewer.model?.materials ?? [];

    for (const material of materials) {
      const profile =
        CANOPTICON_MATERIALS[material.name] ?? DEFAULT_CANOPTICON_MATERIAL;
      const pbr = material.pbrMetallicRoughness;

      pbr.setMetallicFactor(profile.metallic);
      pbr.setRoughnessFactor(profile.roughness);
      material.setSpecularFactor(profile.specular);
      material.setDoubleSided(profile.doubleSided);
      material.setAlphaMode('OPAQUE');
    }
  };

  const applyMaterialProfile = (viewer) => {
    switch (viewer.dataset.materialProfile) {
      case 'canopticon':
        applyCanopticonMaterials(viewer);
        break;
      default:
        break;
    }
  };

  const initializeMaterialProfiles = () => {
    const viewers = document.querySelectorAll('model-viewer[data-material-profile]');

    for (const viewer of viewers) {
      if (viewer.dataset.materialProfileInitialized === 'true') {
        continue;
      }

      viewer.dataset.materialProfileInitialized = 'true';
      viewer.addEventListener('load', () => applyMaterialProfile(viewer), {
        once: true,
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeMaterialProfiles, {
      once: true,
    });
  } else {
    initializeMaterialProfiles();
  }

  document.querySelectorAll<HTMLElement>('.mv-wrap').forEach(wrap => {
    wrap.addEventListener('wheel', (e) => {
      if (!wrap.classList.contains('mv-active')) e.stopPropagation();
    }, { capture: true, passive: true });

    wrap.addEventListener('click', () => wrap.classList.add('mv-active'));

    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) wrap.classList.remove('mv-active');
    });
  });
</script>

<style>
  .mv-wrap {
    position: relative;
    margin: var(--space-lg) 0;
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }



  model-viewer {
    width: 100%;
    height: 560px;
    background-color: transparent;
    --progress-bar-color: transparent;
    --progress-mask: transparent;
    display: block;
  }

</style>
