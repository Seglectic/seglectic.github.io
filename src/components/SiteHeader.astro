---
const navLinks = [
  { label: 'Projects', href: '/projects' },
  { label: 'Devlog',   href: '/devlog'   },
  { label: 'About',    href: '/about'    },
];

const currentPath = Astro.url.pathname;
---

<header>
  <a class="logo" href="/">
    <span class="logo-row"><span class="logo-seg">SEG</span><span class="logo-lectic">LECTIC</span></span>
    <span class="logo-row logo-row--systems"><span class="logo-sys">SYS</span><span class="logo-tems">TEMS</span></span>
  </a>

  <div class="header-inner">
    <nav aria-label="Site navigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
    min-height: 88px;
    user-select: none;
  }

  .header-inner {
    position: relative;
    width: 100%;
    min-height: 88px;
    padding: var(--space-md) var(--space-lg);
  }

  /* Logo */
  .logo {
    position: absolute;
    left: calc(var(--space-lg) + 4px);
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    font-family: var(--font-logo);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    white-space: nowrap;
  }

  .logo-row {
    display: block;
  }

  .logo-row--systems {
    padding-left: 1.01ch; /* ← shift SYSTEMS left/right to align S under E */
  }

  .logo-seg { color: var(--accent); }
  .logo-lectic { color: var(--text); }
  .logo-sys { color: var(--accent); }
  .logo-tems { color: var(--text); }

  .logo:hover .logo-seg,
  .logo:hover .logo-lectic,
  .logo:hover .logo-sys,
  .logo:hover .logo-tems {
    color: var(--accent);
  }

  /* Nav */
  nav {
    position: absolute;
    inset: 0 calc(var(--space-lg) + 4px);
    z-index: 1;
  }

  nav ul {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
  }

  nav li {
    position: absolute;
    top: 0;
    bottom: 0;
    height: 88px;
  }

  nav li:nth-child(1) {
    left: 33.333%;
    right: 33.333%;
  }

  nav li:nth-child(2) {
    left: 66.666%;
    right: 16.666%;
  }

  nav li:nth-child(3) {
    right: 0;
    width: 16.666%;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--accent);
  }

  /* Responsive: tighten nav gap on small screens */
  @media (max-width: 480px) {
    header {
      min-height: 0;
    }

    .header-inner {
      min-height: 0;
      padding: var(--space-sm) var(--space-md);
    }

    .logo {
      position: static;
      transform: none;
      padding: var(--space-sm) var(--space-md) 0;
    }

    nav {
      position: static;
      inset: auto;
    }

    nav ul {
      display: flex;
      width: 100%;
      gap: var(--space-md);
      height: auto;
    }

    nav li,
    nav li:nth-child(1),
    nav li:nth-child(2),
    nav li:nth-child(3) {
      position: static;
      width: 100%;
      height: auto;
      flex: 1 1 0;
    }

    .nav-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 44px;
    }

    .logo-row--systems {
      display: none;
    }
  }
</style>
