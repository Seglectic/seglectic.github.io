---
const navLinks = [
  { label: 'Projects', href: '/projects' },
  { label: 'Devlog',   href: '/devlog'   },
  { label: 'About',    href: '/about'    },
];

const currentPath = Astro.url.pathname;
---

<header>
  <div class="header-inner">
    <a class="logo" href="/">
      <span class="logo-row"><span class="logo-seg">SEG</span><span class="logo-lectic">LECTIC</span></span>
      <span class="logo-row logo-row--systems"><span class="logo-sys">SYS</span><span class="logo-tems">TEMS</span></span>
    </a>

    <nav aria-label="Site navigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    padding: var(--space-md) var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  /* Logo */
  .logo {
    font-family: var(--font-logo);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    white-space: nowrap;
  }

  .logo-row {
    display: block;
  }

  .logo-row--systems {
    padding-left: 1.01ch; /* ← shift SYSTEMS left/right to align S under E */
  }

  .logo-seg { color: var(--accent); }
  .logo-lectic { color: var(--text); }
  .logo-sys { color: var(--accent); }
  .logo-tems { color: var(--text); }

  .logo:hover .logo-seg,
  .logo:hover .logo-lectic,
  .logo:hover .logo-sys,
  .logo:hover .logo-tems {
    color: var(--accent);
  }

  /* Nav */
  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-lg);
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--accent);
  }

  /* Responsive: tighten nav gap on small screens */
  @media (max-width: 480px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
    }

    nav ul {
      gap: var(--space-md);
    }

    .logo-row--systems {
      display: none;
    }
  }
</style>
