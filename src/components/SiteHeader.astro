---
const navLinks = [
  { label: 'Projects', href: '/projects' },
  { label: 'Devlog',   href: '/devlog'   },
  { label: 'About',    href: '/about'    },
];

const currentPath = Astro.url.pathname;
---

<header>
  <div class="header-inner">
    <a class="logo" href="/">
      <span class="logo-row"><span class="logo-seg">SEG</span><span class="logo-lectic">LECTIC</span></span>
      <span class="logo-row logo-row--systems"><span class="logo-sys">SYS</span><span class="logo-tems">TEMS</span></span>
    </a>

    <nav aria-label="Site navigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
    user-select: none;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    width: 100%;
    min-height: 88px;
    padding: 0.95rem var(--space-lg) 0.85rem;
  }

  /* Logo */
  .logo {
    font-family: var(--font-logo);
    font-size: clamp(0.98rem, 0.38vw + 0.9rem, 1.15rem);
    letter-spacing: 0.05em;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    white-space: nowrap;
    flex: 0 1 auto;
    min-width: 0;
  }

  .logo-row {
    display: block;
  }

  .logo-row--systems {
    padding-left: 1.01ch; /* ← shift SYSTEMS left/right to align S under E */
  }

  .logo-seg { color: var(--accent); }
  .logo-lectic { color: var(--text); }
  .logo-sys { color: var(--accent); }
  .logo-tems { color: var(--text); }

  .logo:hover .logo-seg,
  .logo:hover .logo-lectic,
  .logo:hover .logo-sys,
  .logo:hover .logo-tems {
    color: var(--accent);
  }

  /* Nav */
  nav {
    margin-left: auto;
    flex: 1 1 22rem;
    min-width: min(100%, 22rem);
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: flex-end;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 0.45rem 0.8rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    padding: 0.2rem 0.75rem;
    position: relative;
    background: transparent;
    font-family: var(--font-mono);
    font-size: clamp(0.82rem, 0.18vw + 0.78rem, 0.92rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: calc(0.8rem - 0.55ch);
    right: calc(0.8rem - 0.55ch);
    bottom: 0.42rem;
    height: 1px;
    background: var(--accent);
    opacity: 0;
    transform: scaleX(0.65);
    transform-origin: center;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  .nav-link.active {
    background: transparent;
    color: var(--text);
  }

  .nav-link.active::after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media (max-width: 860px) {
    .header-inner {
      align-items: flex-start;
      min-height: 0;
      gap: 0.8rem var(--space-md);
      padding: 0.8rem var(--space-lg) 0.75rem;
    }

    nav {
      flex-basis: 100%;
      min-width: 0;
      margin-left: 0;
    }

    nav ul {
      justify-content: flex-start;
      gap: 0.35rem 0.55rem;
    }

    .nav-link {
      min-height: 2.3rem;
      padding: 0.16rem 0.62rem;
      font-size: clamp(0.76rem, 0.14vw + 0.74rem, 0.84rem);
    }
  }

  @media (max-width: 480px) {
    .header-inner {
      gap: 0.55rem 0.75rem;
      padding: 0.7rem var(--space-md) 0.65rem;
    }

    .logo {
      font-size: clamp(0.82rem, 2.7vw, 0.94rem);
      gap: 0.12em;
    }

    nav ul {
      gap: 0.3rem 0.45rem;
    }

    .nav-link {
      min-height: 2.05rem;
      padding: 0.12rem 0.5rem;
      font-size: 0.7rem;
    }
  }

  @media (max-width: 360px) {
    .logo {
      font-size: 0.76rem;
      letter-spacing: 0.04em;
      gap: 0.1em;
    }

    .logo-row--systems {
      padding-left: 0.9ch;
    }

    .nav-link {
      min-height: 1.95rem;
      padding: 0.1rem 0.42rem;
      font-size: 0.66rem;
    }
  }
</style>

<script>
  const syncHeaderActiveLink = () => {
    const currentPath = window.location.pathname;
    const links = document.querySelectorAll('header .nav-link');

    for (const link of links) {
      if (!(link instanceof HTMLAnchorElement)) continue;
      const isActive = link.pathname !== '/' && currentPath.startsWith(link.pathname);
      link.classList.toggle('active', isActive);
    }
  };

  syncHeaderActiveLink();

  if (!window.__seglecticHeaderBound) {
    document.addEventListener('astro:page-load', syncHeaderActiveLink);
    window.__seglecticHeaderBound = true;
  }
</script>
