---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import HeroFloatingOverlay from '../components/HeroFloatingOverlay.astro';
import Layout from '../layouts/Layout.astro';
import DevlogCard from '../components/DevlogCard.astro';
import { devlogProject } from '../lib/content';
import { getSocialPreviewUrl } from '../lib/social-preview';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);

const allDevlog = await getCollection('devlog');
const relatedDevlog = allDevlog
  .filter((post: CollectionEntry<'devlog'>) => devlogProject(post.id) === project.id && post.data.publish)
  .sort((a: CollectionEntry<'devlog'>, b: CollectionEntry<'devlog'>) => b.data.date.valueOf() - a.data.date.valueOf());
const socialImage = await getSocialPreviewUrl(project.filePath);

const { title, tagline, heroImage, heroOverlay, github, demo, docs } = project.data;
const isCanopticonHero = heroOverlay?.variant === 'canopticon';
---

<Layout
  title={`${title} — Seglectic Systems`}
  description={project.data.summary}
  bodyClass={isCanopticonHero ? 'canopticon-page' : undefined}
  socialImage={socialImage}
>
  {heroImage && (
    <section class:list={[
      'hero-image-wrap',
      isCanopticonHero && 'hero-image-wrap--canopticon',
    ]}>
      <Image src={heroImage} alt={`${title} hero`} class="hero-image" />
      {heroOverlay && <HeroFloatingOverlay overlay={heroOverlay} projectTitle={title} />}
      <div class="hero-overlay">
        <div class="hero-copy">
          <h1 class:list={[
            'title',
            'hero-reveal',
            'hero-reveal--title',
            isCanopticonHero && 'title--anta',
          ]}>{title}</h1>
          <p class="tagline hero-reveal hero-reveal--tagline">{tagline}</p>
        </div>
      </div>
    </section>
  )}

  <article class:list={[
    'project-wrap',
    isCanopticonHero && 'project-wrap--wide',
  ]} data-reveal>
    <header class="project-header">
      <p class="summary">{project.data.summary}</p>
    </header>

    <div class="project-body" data-reveal>
      <Content />
    </div>

    {(github || demo || docs) && (
      <div class="quick-links quick-links--details" data-reveal>
        {github && (
          <a href={github} class="link-btn" target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        )}
        {demo && (
          <a href={demo} class="link-btn" target="_blank" rel="noopener noreferrer">
            Demo
          </a>
        )}
        {docs && (
          <a href={docs} class="link-btn" target="_blank" rel="noopener noreferrer">
            Docs
          </a>
        )}
      </div>
    )}

    {relatedDevlog.length > 0 && (
      <section class="related-devlog" data-reveal>
        <h2 class="related-title">Devlog</h2>
        <div class="devlog-list">
          {relatedDevlog.map((post: CollectionEntry<'devlog'>) => (
            <DevlogCard post={post} />
          ))}
        </div>
      </section>
    )}
  </article>

  <div class="lightbox" data-lightbox hidden>
    <button class="lightbox-close" type="button" aria-label="Close image viewer" data-lightbox-close>
      Close
    </button>
    <div class="lightbox-dialog" role="dialog" aria-modal="true" aria-label="Expanded image view">
      <img class="lightbox-image" alt="" data-lightbox-image />
    </div>
  </div>
</Layout>

<style>
  .project-wrap {
    padding: clamp(1.25rem, 3vw, 2rem) 0 var(--space-xl);
    max-width: 800px;
    scroll-margin-top: 104px;
  }

  .project-wrap--wide {
    max-width: 1120px;
  }

  .project-header {
    margin-bottom: calc(var(--space-lg) + var(--space-sm));
  }

  .hero-image-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-bottom: 0;
    overflow: hidden;
    min-height: 100vh;
    background: var(--bg-surface);
    --hero-scroll-progress: 0;
  }

  .hero-image {
    width: 100%;
    min-height: 100vh;
    height: 100vh;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
    transform: scale(calc(1 + (var(--hero-scroll-progress) * 0.06))) translateY(calc(var(--hero-scroll-progress) * 3.5vh));
    will-change: transform;
  }

  .hero-image-wrap--canopticon {
    background: transparent;
  }

  .hero-image-wrap--canopticon .hero-image {
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 67%, rgba(0, 0, 0, 0.95) 75%, rgba(0, 0, 0, 0.78) 82%, rgba(0, 0, 0, 0.5) 88%, rgba(0, 0, 0, 0.24) 93%, rgba(0, 0, 0, 0.08) 97%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 0%, #000 67%, rgba(0, 0, 0, 0.95) 75%, rgba(0, 0, 0, 0.78) 82%, rgba(0, 0, 0, 0.5) 88%, rgba(0, 0, 0, 0.24) 93%, rgba(0, 0, 0, 0.08) 97%, transparent 100%);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
    transform: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    z-index: 2;
    background:
      linear-gradient(180deg, rgba(15, 15, 15, 0) 0%, rgba(15, 15, 15, 0.06) 38%, rgba(15, 15, 15, 0.28) 58%, rgba(15, 15, 15, 0.6) 74%, rgba(15, 15, 15, 0.86) 88%, rgba(15, 15, 15, 0.96) 100%);
  }

  .hero-image-wrap--canopticon .hero-overlay {
    background:
      radial-gradient(circle at 50% 80%, rgba(8, 8, 10, 0.42) 0%, rgba(8, 8, 10, 0.22) 16%, rgba(8, 8, 10, 0.08) 30%, rgba(8, 8, 10, 0) 50%),
      linear-gradient(180deg, rgba(15, 15, 15, 0.16) 0%, rgba(15, 15, 15, 0.07) 26%, rgba(15, 15, 15, 0.015) 44%, rgba(15, 15, 15, 0) 66%);
  }

  .hero-copy {
    width: min(100%, 1240px);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3.5rem) var(--space-lg) clamp(3.5rem, 8vw, 6rem);
    transform: translateY(calc(var(--hero-scroll-progress) * -5vh));
    opacity: calc(1 - (var(--hero-scroll-progress) * 0.32));
    will-change: transform, opacity;
  }

  .title {
    font-family: "Segoe UI", "Aptos", "Helvetica Neue", "Arial Nova", sans-serif;
    font-size: clamp(2.75rem, 7vw, 6rem);
    font-weight: 300;
    color: #fbfbf7;
    margin: 0;
    letter-spacing: 0.045em;
    line-height: 0.92;
    text-transform: uppercase;
    max-width: 11ch;
    text-wrap: balance;
    text-shadow: 0 0 24px rgba(15, 15, 15, 0.28);
  }

  .title--anta {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.03em;
    text-transform: none;
  }

  .tagline {
    font-family: "IBM Plex Mono", "Aptos Mono", "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", monospace;
    color: rgba(232, 232, 230, 0.78);
    font-size: clamp(0.95rem, 1.45vw, 1.1rem);
    line-height: 1.75;
    margin: calc(var(--space-md) + 2px) 0 0 0;
    max-width: 32rem;
    letter-spacing: 0.02em;
    text-wrap: pretty;
  }

  .hero-reveal {
    opacity: 0;
    transform: translateY(26px);
    animation: hero-fade-up 900ms cubic-bezier(0.18, 0.82, 0.22, 1) forwards;
    will-change: transform, opacity;
  }

  .hero-reveal--title {
    animation-delay: 160ms;
  }

  .hero-reveal--tagline {
    animation-delay: 320ms;
  }

  .quick-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .quick-links--details {
    margin-bottom: var(--space-xl);
  }

  .link-btn {
    display: inline-block;
    padding: 0.45rem 0.9rem;
    border: 1px solid rgba(232, 232, 230, 0.28);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: rgba(243, 241, 235, 0.84);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(15, 15, 15, 0.18);
    backdrop-filter: blur(12px);
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .link-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(15, 15, 15, 0.36);
  }

  .summary {
    margin: 0;
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .project-wrap--wide .summary {
    color: rgba(244, 244, 239, 0.94);
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 700ms cubic-bezier(0.18, 0.82, 0.22, 1),
      transform 700ms cubic-bezier(0.18, 0.82, 0.22, 1);
    will-change: transform, opacity;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-body {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .project-wrap--wide .project-body {
    color: rgba(236, 236, 232, 0.9);
  }

  .project-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: var(--space-lg) 0;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-surface);
  }

  .project-body :global([data-lightboxable]) {
    cursor: zoom-in;
  }

  .project-body :global(h1) {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 400;
    color: #f4f4ee;
    margin: var(--space-lg) 0 var(--space-sm) 0;
    letter-spacing: 0.04em;
  }

  .project-body :global(h2) {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text);
    margin: var(--space-lg) 0 var(--space-sm) 0;
    letter-spacing: 0.04em;
  }

  .project-body :global(h3) {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-muted);
    margin: var(--space-md) 0 var(--space-xs) 0;
  }

  .project-wrap--wide .project-body :global(h3) {
    color: rgba(225, 225, 219, 0.84);
  }

  .project-body :global(ul) {
    padding-left: var(--space-lg);
  }

  .project-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .project-body :global(p) {
    margin: 0 0 var(--space-md) 0;
  }

  .project-body :global(.media-split) {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
    align-items: start;
    margin: var(--space-lg) 0;
  }

  .project-body :global(.media-split img) {
    width: 100%;
    margin: 0;
  }

  .project-body :global(.media-split__copy) {
    padding-top: 0.15rem;
  }

  .project-body :global(.media-split__copy p:last-child) {
    margin-bottom: 0;
  }

  .related-devlog {
    border-top: 1px solid var(--border);
    padding-top: var(--space-lg);
  }

  .related-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 var(--space-md) 0;
  }

  .devlog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 3vw, 2rem);
    background: rgba(4, 4, 6, 0.82);
    backdrop-filter: blur(8px);
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-dialog {
    max-width: min(92vw, 1400px);
    max-height: 90vh;
  }

  .lightbox-image {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    width: auto;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
    background: rgba(10, 10, 12, 0.96);
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    border: 1px solid rgba(232, 232, 230, 0.28);
    background: rgba(15, 15, 15, 0.55);
    color: var(--text);
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(26px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 720px) {
    .project-wrap {
      padding-top: var(--space-md);
    }

    .hero-copy {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
      padding-bottom: calc(var(--space-xl) + var(--space-md));
    }
    .title {
      max-width: none;
    }

    .project-body :global(.media-split) {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image,
    .hero-copy {
      transform: none;
      opacity: 1;
      will-change: auto;
    }

    .hero-reveal,
    [data-reveal] {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  const initProjectReveals = () => {
    const revealTargets = Array.from(document.querySelectorAll('[data-reveal]'));
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouchLikeViewport =
      window.matchMedia('(pointer: coarse)').matches ||
      window.matchMedia('(hover: none)').matches ||
      window.innerWidth <= 720;

    if (
      revealTargets.length > 0 &&
      !prefersReducedMotion &&
      !isTouchLikeViewport &&
      'IntersectionObserver' in window
    ) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        },
        {
          threshold: 0.16,
          rootMargin: '0px 0px -8% 0px',
        }
      );

      for (const target of revealTargets) {
        target.classList.remove('is-visible');
        observer.observe(target);
      }

      window.setTimeout(() => {
        for (const target of revealTargets) {
          if (!target.classList.contains('is-visible')) {
            target.classList.add('is-visible');
            observer.unobserve(target);
          }
        }
      }, 1400);
    } else {
      for (const target of revealTargets) target.classList.add('is-visible');
    }
  };

  const initHeroScrollEffects = () => {
    const hero = document.querySelector('.hero-image-wrap');
    const article = document.querySelector('.project-wrap');
    if (!hero || !article) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (
      window.matchMedia('(pointer: coarse)').matches ||
      window.matchMedia('(hover: none)').matches ||
      window.innerWidth <= 720
    ) {
      hero.style.setProperty('--hero-scroll-progress', '0');
      return;
    }
    if (hero.dataset.scrollEffectsBound === 'true') return;

    hero.dataset.scrollEffectsBound = 'true';

    let ticking = false;
    let hasSnappedForward = false;
    let snapLock = false;
    let touchStartY = 0;
    let lastScrollY = window.scrollY;

    const updateHeroState = () => {
      ticking = false;

      const heroRect = hero.getBoundingClientRect();
      const heroHeight = Math.max(heroRect.height, window.innerHeight);
      const travelled = Math.min(Math.max(-heroRect.top, 0), heroHeight);
      const progress = Math.min(travelled / heroHeight, 1);

      hero.style.setProperty('--hero-scroll-progress', progress.toFixed(4));

      if (progress < 0.08) {
        hasSnappedForward = false;
      }
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateHeroState);
    };

    const getHeroProgress = () => {
      const heroRect = hero.getBoundingClientRect();
      const heroHeight = Math.max(heroRect.height, window.innerHeight);
      return Math.min(Math.max(-heroRect.top, 0) / heroHeight, 1);
    };

    const snapIntoContent = () => {
      if (snapLock || hasSnappedForward) return;

      const progress = getHeroProgress();

      if (progress < 0.16 || progress > 0.94) return;

      const snapOffset = progress > 0.56 ? 12 : 24;
      const articleTop = article.getBoundingClientRect().top + window.scrollY - snapOffset;
      snapLock = true;
      hasSnappedForward = true;
      window.scrollTo({ top: articleTop, behavior: 'smooth' });

      window.setTimeout(() => {
        snapLock = false;
      }, 900);
    };

    const handleWheel = (event) => {
      if (event.deltaY <= 0) return;
      snapIntoContent();
    };

    const handleScroll = () => {
      const currentScrollY = window.scrollY;
      const scrollingDown = currentScrollY > lastScrollY;
      lastScrollY = currentScrollY;

      requestUpdate();

      if (!scrollingDown || snapLock || hasSnappedForward) return;
      if (getHeroProgress() < 0.62) return;

      snapIntoContent();
    };

    const handleTouchStart = (event) => {
      touchStartY = event.touches[0]?.clientY ?? 0;
    };

    const handleTouchEnd = (event) => {
      const touchEndY = event.changedTouches[0]?.clientY ?? touchStartY;
      if (touchStartY - touchEndY > 36) {
        snapIntoContent();
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('wheel', handleWheel, { passive: true });
    window.addEventListener('touchstart', handleTouchStart, { passive: true });
    window.addEventListener('touchend', handleTouchEnd, { passive: true });

    window.addEventListener(
      'pagehide',
      () => {
        window.removeEventListener('scroll', requestUpdate);
        window.removeEventListener('scroll', handleScroll);
        window.removeEventListener('wheel', handleWheel);
        window.removeEventListener('touchstart', handleTouchStart);
        window.removeEventListener('touchend', handleTouchEnd);
      },
      { once: true }
    );

    updateHeroState();
  };

  const initProjectLightbox = () => {
    const lightbox = document.querySelector('[data-lightbox]');
    const lightboxImage = document.querySelector('[data-lightbox-image]');
    const closeButton = document.querySelector('[data-lightbox-close]');

    if (!lightbox || !lightboxImage || !closeButton) return;
    if (lightbox.dataset.bound === 'true') return;

    const closeLightbox = () => {
      lightbox.hidden = true;
      lightboxImage.removeAttribute('src');
      lightboxImage.alt = '';
      document.body.style.removeProperty('overflow');
    };

    const openLightbox = (sourceImage) => {
      const source = sourceImage.getAttribute('src');
      if (!source) return;

      lightboxImage.src = source;
      lightboxImage.alt = sourceImage.getAttribute('alt') ?? '';
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    document.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-lightboxable]');
      if (trigger instanceof HTMLImageElement) {
        openLightbox(trigger);
        return;
      }

      if (
        event.target === lightbox ||
        event.target === closeButton ||
        event.target.closest('[data-lightbox-close]')
      ) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !lightbox.hidden) {
        closeLightbox();
      }
    });

    lightbox.dataset.bound = 'true';
  };

  const initProjectPage = () => {
    initProjectReveals();
    initHeroScrollEffects();
    initProjectLightbox();
  };

  initProjectPage();

  if (!window.__seglecticProjectPageBound) {
    document.addEventListener('astro:page-load', initProjectPage);
    window.__seglecticProjectPageBound = true;
  }
</script>
