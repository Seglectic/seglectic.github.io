---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import DevlogCard from '../../components/DevlogCard.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);

const allDevlog = await getCollection('devlog');
const relatedDevlog = allDevlog
  .filter((post: CollectionEntry<'devlog'>) => post.data.project === project.id && post.data.publish)
  .sort((a: CollectionEntry<'devlog'>, b: CollectionEntry<'devlog'>) => b.data.date.valueOf() - a.data.date.valueOf());

const { title, tagline, heroImage, logoImage, github, demo, docs } = project.data;
---

<Layout
  title={`${title} — Seglectic Systems`}
  description={project.data.summary}
>
  {heroImage && (
    <section class="hero-image-wrap">
      <Image src={heroImage} alt={`${title} hero`} class="hero-image" />
      {logoImage && (
        <Image
          src={logoImage}
          alt={`${title} logo`}
          class="hero-logo"
          data-canopticon-logo
        />
      )}
      <div class="hero-overlay">
        <div class="hero-copy">
          <h1 class="title hero-reveal hero-reveal--title">{title}</h1>
          <p class="tagline hero-reveal hero-reveal--tagline">{tagline}</p>
        </div>
      </div>
    </section>
  )}

  <article class="project-wrap" data-reveal>
    <header class="project-header">
      <p class="summary">{project.data.summary}</p>
    </header>

    <div class="project-body" data-reveal>
      <Content />
    </div>

    {(github || demo || docs) && (
      <div class="quick-links quick-links--details" data-reveal>
        {github && (
          <a href={github} class="link-btn" target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        )}
        {demo && (
          <a href={demo} class="link-btn" target="_blank" rel="noopener noreferrer">
            Demo
          </a>
        )}
        {docs && (
          <a href={docs} class="link-btn" target="_blank" rel="noopener noreferrer">
            Docs
          </a>
        )}
      </div>
    )}

    {relatedDevlog.length > 0 && (
      <section class="related-devlog" data-reveal>
        <h2 class="related-title">Devlog</h2>
        <div class="devlog-list">
          {relatedDevlog.map((post: CollectionEntry<'devlog'>) => (
            <DevlogCard post={post} />
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  .project-wrap {
    padding: var(--space-xl) 0;
    max-width: 720px;
  }

  .project-header {
    margin-bottom: calc(var(--space-lg) + var(--space-sm));
  }

  .hero-image-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-bottom: calc(var(--space-xl) + var(--space-sm));
    overflow: hidden;
    min-height: 100vh;
    background: var(--bg-surface);
  }

  .hero-image {
    width: 100%;
    min-height: 100vh;
    height: 100vh;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
  }

  .hero-logo {
    position: absolute;
    left: 50%;
    top: 43%;
    width: clamp(110px, 16vw, 168px);
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: contain;
    pointer-events: none;
    filter: drop-shadow(0 14px 34px rgba(0, 0, 0, 0.42));
    will-change: transform;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background:
      linear-gradient(180deg, rgba(15, 15, 15, 0) 0%, rgba(15, 15, 15, 0.04) 42%, rgba(15, 15, 15, 0.46) 76%, rgba(15, 15, 15, 0.92) 100%);
  }

  .hero-copy {
    width: min(100%, 1240px);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3.5rem) var(--space-lg) clamp(3.5rem, 8vw, 6rem);
  }

  .title {
    font-family: "Segoe UI", "Aptos", "Helvetica Neue", "Arial Nova", sans-serif;
    font-size: clamp(2.75rem, 7vw, 6rem);
    font-weight: 300;
    color: #f3f1eb;
    margin: 0;
    letter-spacing: 0.045em;
    line-height: 0.92;
    text-transform: uppercase;
    max-width: 11ch;
    text-wrap: balance;
    text-shadow: 0 0 24px rgba(15, 15, 15, 0.28);
  }

  .tagline {
    font-family: "IBM Plex Mono", "Aptos Mono", "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", monospace;
    color: rgba(232, 232, 230, 0.78);
    font-size: clamp(0.95rem, 1.45vw, 1.1rem);
    line-height: 1.75;
    margin: calc(var(--space-md) + 2px) 0 0 0;
    max-width: 32rem;
    letter-spacing: 0.02em;
    text-wrap: pretty;
  }

  .hero-reveal {
    opacity: 0;
    transform: translateY(26px);
    animation: hero-fade-up 900ms cubic-bezier(0.18, 0.82, 0.22, 1) forwards;
    will-change: transform, opacity;
  }

  .hero-reveal--title {
    animation-delay: 160ms;
  }

  .hero-reveal--tagline {
    animation-delay: 320ms;
  }

  .quick-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .quick-links--details {
    margin-bottom: var(--space-xl);
  }

  .link-btn {
    display: inline-block;
    padding: 0.45rem 0.9rem;
    border: 1px solid rgba(232, 232, 230, 0.28);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: rgba(243, 241, 235, 0.84);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(15, 15, 15, 0.18);
    backdrop-filter: blur(12px);
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .link-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(15, 15, 15, 0.36);
  }

  .summary {
    margin: 0;
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 700ms cubic-bezier(0.18, 0.82, 0.22, 1),
      transform 700ms cubic-bezier(0.18, 0.82, 0.22, 1);
    will-change: transform, opacity;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-body {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .project-body :global(h2) {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text);
    margin: var(--space-lg) 0 var(--space-sm) 0;
    letter-spacing: 0.04em;
  }

  .project-body :global(h3) {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-muted);
    margin: var(--space-md) 0 var(--space-xs) 0;
  }

  .project-body :global(ul) {
    padding-left: var(--space-lg);
  }

  .project-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .project-body :global(p) {
    margin: 0 0 var(--space-md) 0;
  }

  .related-devlog {
    border-top: 1px solid var(--border);
    padding-top: var(--space-lg);
  }

  .related-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 var(--space-md) 0;
  }

  .devlog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  @media (max-width: 720px) {
    .hero-copy {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
      padding-bottom: calc(var(--space-xl) + var(--space-md));
    }

    .title {
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal,
    [data-reveal] {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(26px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const initProjectReveals = () => {
    const revealTargets = Array.from(document.querySelectorAll('[data-reveal]'));

    if (
      revealTargets.length > 0 &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
      'IntersectionObserver' in window
    ) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        },
        {
          threshold: 0.16,
          rootMargin: '0px 0px -8% 0px',
        }
      );

      for (const target of revealTargets) {
        target.classList.remove('is-visible');
        observer.observe(target);
      }
    } else {
      for (const target of revealTargets) target.classList.add('is-visible');
    }
  };

  const initCanopticonLogoBob = () => {
    const logo = document.querySelector('[data-canopticon-logo]');
    if (!logo) return;

    const amplitude = 12;
    const periodMs = 2000;
    const startedAt = performance.now();
    let frameId = 0;

    const tick = (now) => {
      const phase = ((now - startedAt) / periodMs) * Math.PI * 2;
      const offsetY = Math.sin(phase) * amplitude;
      logo.style.transform = `translate(-50%, calc(-50% + ${offsetY.toFixed(2)}px))`;
      frameId = window.requestAnimationFrame(tick);
    };

    frameId = window.requestAnimationFrame(tick);

    window.addEventListener(
      'pagehide',
      () => {
        window.cancelAnimationFrame(frameId);
      },
      { once: true }
    );
  };

  const initProjectPage = () => {
    initProjectReveals();
    initCanopticonLogoBob();
  };

  initProjectPage();

  if (!window.__seglecticProjectPageBound) {
    document.addEventListener('astro:page-load', initProjectPage);
    window.__seglecticProjectPageBound = true;
  }
</script>
