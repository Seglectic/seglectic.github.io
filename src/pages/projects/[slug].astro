---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import DevlogCard from '../../components/DevlogCard.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);

const allDevlog = await getCollection('devlog');
const relatedDevlog = allDevlog
  .filter((post: CollectionEntry<'devlog'>) => post.data.project === project.id && post.data.publish)
  .sort((a: CollectionEntry<'devlog'>, b: CollectionEntry<'devlog'>) => b.data.date.valueOf() - a.data.date.valueOf());

const { title, tagline, status, category, heroImage, github, demo, docs } = project.data;
---

<Layout
  title={`${title} — Seglectic Systems`}
  description={project.data.summary}
>
  {heroImage && (
    <section class="hero-image-wrap">
      <Image src={heroImage} alt={`${title} hero`} class="hero-image" />
      <div class="hero-overlay">
          <div class="hero-copy">
          <h1 class="title">{title}</h1>
          <p class="tagline">{tagline}</p>
        </div>
      </div>
    </section>
  )}

  <article class="project-wrap">
    <header class="project-header">
      <p class="summary">{project.data.summary}</p>
    </header>

    <div class="project-body">
      <Content />
    </div>

    {(github || demo || docs) && (
      <div class="quick-links quick-links--details">
        {github && (
          <a href={github} class="link-btn" target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        )}
        {demo && (
          <a href={demo} class="link-btn" target="_blank" rel="noopener noreferrer">
            Demo
          </a>
        )}
        {docs && (
          <a href={docs} class="link-btn" target="_blank" rel="noopener noreferrer">
            Docs
          </a>
        )}
      </div>
    )}

    {relatedDevlog.length > 0 && (
      <section class="related-devlog">
        <h2 class="related-title">Devlog</h2>
        <div class="devlog-list">
          {relatedDevlog.map((post: CollectionEntry<'devlog'>) => (
            <DevlogCard post={post} />
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  .project-wrap {
    padding: var(--space-xl) 0;
    max-width: 720px;
  }

  .project-header {
    margin-bottom: calc(var(--space-lg) + var(--space-sm));
  }

  .hero-image-wrap {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-bottom: calc(var(--space-xl) + var(--space-sm));
    overflow: hidden;
    min-height: 100vh;
    background: var(--bg-surface);
  }

  .hero-image {
    width: 100%;
    min-height: 100vh;
    height: 100vh;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background:
      linear-gradient(180deg, rgba(15, 15, 15, 0) 0%, rgba(15, 15, 15, 0.04) 42%, rgba(15, 15, 15, 0.46) 76%, rgba(15, 15, 15, 0.92) 100%);
  }

  .hero-copy {
    width: min(100%, 1240px);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3.5rem) var(--space-lg) clamp(3.5rem, 8vw, 6rem);
  }

  .title {
    font-family: "Segoe UI", "Aptos", "Helvetica Neue", "Arial Nova", sans-serif;
    font-size: clamp(2.75rem, 7vw, 6rem);
    font-weight: 300;
    color: #f3f1eb;
    margin: 0;
    letter-spacing: 0.045em;
    line-height: 0.92;
    text-transform: uppercase;
    max-width: 11ch;
    text-wrap: balance;
    text-shadow: 0 0 24px rgba(15, 15, 15, 0.28);
  }

  .tagline {
    font-family: "IBM Plex Mono", "Aptos Mono", "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", monospace;
    color: rgba(232, 232, 230, 0.78);
    font-size: clamp(0.95rem, 1.45vw, 1.1rem);
    line-height: 1.75;
    margin: calc(var(--space-md) + 2px) 0 0 0;
    max-width: 32rem;
    letter-spacing: 0.02em;
    text-wrap: pretty;
  }

  .quick-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .quick-links--details {
    margin-bottom: var(--space-xl);
  }

  .link-btn {
    display: inline-block;
    padding: 0.45rem 0.9rem;
    border: 1px solid rgba(232, 232, 230, 0.28);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: rgba(243, 241, 235, 0.84);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(15, 15, 15, 0.18);
    backdrop-filter: blur(12px);
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .link-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(15, 15, 15, 0.36);
  }

  .summary {
    margin: 0;
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .project-body {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .project-body :global(h2) {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text);
    margin: var(--space-lg) 0 var(--space-sm) 0;
    letter-spacing: 0.04em;
  }

  .project-body :global(h3) {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-muted);
    margin: var(--space-md) 0 var(--space-xs) 0;
  }

  .project-body :global(ul) {
    padding-left: var(--space-lg);
  }

  .project-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .project-body :global(p) {
    margin: 0 0 var(--space-md) 0;
  }

  .related-devlog {
    border-top: 1px solid var(--border);
    padding-top: var(--space-lg);
  }

  .related-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 var(--space-md) 0;
  }

  .devlog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  @media (max-width: 720px) {
    .hero-copy {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
      padding-bottom: calc(var(--space-xl) + var(--space-md));
    }

    .title {
      max-width: none;
    }
  }
</style>
